@model UpdateCategoryDto

<h1>Kategori Güncelleme Sayfası</h1>

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">Yeni Kategori Ekleme Sayfası</h6>
                <form asp-area="Admin" asp-controller="Category" asp-action="UpdateCategory">
                    <input type="hidden" asp-for="@Model.CategoryID" />
                    <label>Kategori Adı</label>
                    <input asp-for="CategoryName" class="form-control" />
                    <br />
                    <div class="form-check">
                        <input class="form-check-input" asp-for="@Model.CategoryStatus">
                        <label class="form-check-label" asp-for="@Model.CategoryStatus">
                            Aktif mi?
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary mt-3" >Kategoriyi Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>