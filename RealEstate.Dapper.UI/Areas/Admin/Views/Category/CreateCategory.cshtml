@model CreateCategoryDto
<h1>Yeni Kategori Ekleme Sayfası</h1>

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">Yeni Kategori Ekleme Sayfası</h6>
                <form asp-area="Admin" asp-controller="Category" asp-action="CreateCategory">
                    <label>Kategori Adı</label>
                    <input asp-for="CategoryName" class="form-control" />
                    <br />
                    <button class="btn btn-primary">Kategoriyi Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>