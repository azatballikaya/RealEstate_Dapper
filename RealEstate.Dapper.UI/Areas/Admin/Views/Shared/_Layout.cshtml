@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_AdminLayoutHeader")

<body>
    <div class="container-xxl position-relative bg-white d-flex p-0">
        <!-- Spinner Start -->
        @await Component.InvokeAsync("_AdminLayoutSpinner")
        <!-- Spinner End -->


        <!-- Sidebar Start -->
        @await Component.InvokeAsync("_AdminLayoutSidebar")
        <!-- Sidebar End -->


        <!-- Content Start -->
    <div class="content">

            <!-- Navbar Start -->
            @await Component.InvokeAsync("_AdminLayoutNavbar")
            <!-- Navbar End -->
            @RenderBody()
            <!-- Footer Start -->
            @await Component.InvokeAsync("_AdminLayoutFooter")
            <!-- Footer End -->
    </div>
      
        <!-- Content End -->
        <!-- Back to Top -->
        <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>

    <!-- JavaScript Libraries -->
   @await Component.InvokeAsync("_AdminLayoutScripts")
</body>

</html>